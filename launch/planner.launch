<launch>

    <arg name="octomap_file" default="$(find mapping_simulator)/octo_binary/octomap.bt" />


    <!-- 设置起点和终点 -->
    <param name="start_x" value="-13.5" />
    <param name="start_y" value="10.5" />
    <param name="start_z" value="1.0" />

    <param name="goal_x" value="13.0" />
    <param name="goal_y" value="-7.0" />
    <param name="goal_z" value="1.0" />

    <node name="rrtstar" pkg="mapping_simulator" type="rrtstar" output="screen">
        <param name="octomap_file" value="$(arg octomap_file)" />
    </node>


    <node type="rviz" name="rviz" pkg="rviz" args="-d $(find mapping_simulator)/rviz/esdf_gen.rviz" ></node>


  </launch>
